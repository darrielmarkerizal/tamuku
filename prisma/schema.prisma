generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TtdStatus {
  WEEKLY_ROUTINE
  MENSTRUATION_ROUTINE
}

enum InventoryReason {
  CONSUMED
  RECEIVED
  CORRECTION
}

enum MenstruationSource {
  MANUAL
  AUTO_CLOSE
}

enum Mood {
  HAPPY
  CALM
  SAD
  ANGRY
  TIRED
  ANXIOUS
}

enum Symptom {
  CRAMP
  HEADACHE
  BLOATING
  ACNE
  FATIGUE
  BACKPAIN
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  username             String    @unique
  password             String
  name                 String?
  email                String?
  school               String?
  class_name           String?
  birth_date           DateTime? @db.Date

  inventory_ttd        Int       @default(0)

  badges               String[]  @default([])
  streak_current       Int       @default(0)
  streak_longest       Int       @default(0)
  streak_last_week_iso String?

  streak_freeze_weeks  String[]  @default([])
  streak_freeze_left   Int       @default(1)
  streak_freeze_month  String?

  equipped_accessory   String?

  discreet_mode        Boolean   @default(false)

  seen_flashcards      String[]  @default([])

  consent_accepted_at  DateTime?
  guardian_aware       Boolean   @default(false)
  onboarding_completed Boolean   @default(false)

  last_login_at        DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  menstruationLogs     MenstruationLog[]
  ttdLogs              TtdLog[]
  inventoryAdjustments InventoryAdjustment[]
  journalLogs          JournalLog[]
  notificationSetting  NotificationSetting?
  pushSubscriptions    PushSubscription[]
  idempotencyKeys      IdempotencyKey[]

  @@index([deletedAt])
  @@index([last_login_at])
}

model MenstruationLog {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @db.Uuid
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  start_date    DateTime           @db.Date
  end_date      DateTime?          @db.Date
  cycle_length  Int?
  period_length Int?
  source        MenstruationSource @default(MANUAL)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId, start_date])
  @@index([userId, end_date])
}

model TtdLog {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  log_date           DateTime  @db.Date
  status             TtdStatus
  flashcard_shown_id String?
  createdAt          DateTime  @default(now())

  @@unique([userId, log_date])
  @@index([userId, log_date])
}

model InventoryAdjustment {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    InventoryReason
  note      String?
  createdAt DateTime        @default(now())

  @@index([userId, createdAt])
}

model JournalLog {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  log_date  DateTime  @db.Date
  mood      Mood?
  symptoms  Symptom[] @default([])
  notes     String?   @db.VarChar(280)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, log_date])
  @@index([userId, log_date])
}

model NotificationSetting {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  enabled           Boolean  @default(true)

  reminder_hour     Int      @default(19)
  reminder_minute   Int      @default(0)

  weekly_day        Int      @default(5)

  ttd_daily         Boolean  @default(true)
  ttd_weekly        Boolean  @default(true)
  period_start      Boolean  @default(true)
  period_prediction Boolean  @default(true)
  low_stock         Boolean  @default(true)
  badge_earned      Boolean  @default(true)

  quiet_start_hour  Int      @default(21)
  quiet_end_hour    Int      @default(6)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  user_agent String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model IdempotencyKey {
  key       String   @id
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
